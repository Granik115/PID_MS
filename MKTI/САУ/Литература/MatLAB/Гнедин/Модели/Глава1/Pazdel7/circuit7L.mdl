      ShowName		      off
      TreatAsAtomicUnit	      off
      MaskType		      "Nonlinear Inductance"
      MaskPromptString	      "Nominal voltage (Volts rms) :|Nominal frequency"
" (Hz):|Unsaturated inductance (H):|Saturation characteristic [i1(pu) phi1(pu)"
"; i2 phi2; ...]:"
      MaskStyleString	      "edit,edit,edit,edit"
      MaskTunableValueString  "on,on,on,on"
      MaskCallbackString      "|||"
      MaskEnableString	      "on,on,on,on"
      MaskVisibilityString    "on,on,on,on"
      MaskToolTipString	      "on,on,on,on"
      MaskVarAliasString      ",,,"
      MaskVariables	      "Vnom=@1;fnom=@2;L=@3;sat=@4;"
      MaskInitialization      "% Define base current and Flux for p.u. system"
"\nI_base=Vnom*sqrt(2)/(L*2*pi*fnom);\nPhi_base=Vnom*sqrt(2)/(2*pi*fnom);\n% C"
"heck first two points of the saturation characteristic\nif ~all(all(sat(1:2,:"
")==[0 0; 1 1])),\nh=errordlg('The first two points of the characteristic must"
" be [0 0; 1 1]','Error');\nuiwait(h);\nend\n% Complete negative part of satur"
"ation characteristic\n[npoints,ncol]=size(sat);\nsat1=[sat ; -sat(2:npoints,:"
")];\nsat1=sort(sat1);\n% Current vector (A) and flux vector (V.s)\nCurrent_ve"
"ct=sat1(:,1)*I_base;\nFlux_vect=sat1(:,2)*Phi_base;"
      MaskDisplay	      "plot(Current_vect,Flux_vect)"
