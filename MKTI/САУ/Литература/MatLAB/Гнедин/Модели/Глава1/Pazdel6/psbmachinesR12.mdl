    Block {
      BlockType		      SubSystem
      Name		      "More Info"
      Ports		      []
      Position		      [837, 411, 867, 440]
      DropShadow	      on
      ShowPortLabels	      on
      TreatAsAtomicUnit	      off
      RTWSystemCode	      "Auto"
      RTWFcnNameOpts	      "Auto"
      RTWFileNameOpts	      "Auto"
